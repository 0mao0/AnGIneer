# ============================================================
# AnGIneer 部署环境变量配置
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# ============================================================

# --- LLM 配置 ---
# 支持多个模型配置，格式为 JSON 字符串
# 每个 model 配置包含: name, model, api_key, base_url
LLM_CONFIGS=[
  {
    "name": "Qwen3.6-35B-A3B",
    "model": "Qwen/Qwen3-35B-A3B",
    "api_key": "YOUR_API_KEY_HERE",
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1"
  }
]

# --- Embedding / Reranker API（云端服务）---
EMBEDDING_API_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_API_KEY=YOUR_EMBEDDING_API_KEY_HERE
RERANKER_API_URL=https://api.siliconflow.cn/v1/rerank
RERANKER_API_KEY=YOUR_RERANKER_API_KEY_HERE

# --- MinerU 云端解析 ---
MINERU_API_KEY=YOUR_MINERU_API_KEY_HERE
MINERU_BASE_URL=https://mineru.net/api/v4

# --- 日志级别 ---
LOG_LEVEL=INFO
