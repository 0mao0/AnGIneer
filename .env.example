# ============================================================
# AnGIneer 部署环境变量配置
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# ============================================================

# --- AI Provider (可选: aliyun) ---
AI_PROVIDER=aliyun

# 默认模型 (config_name 未指定时使用)
ANGINEER_DEFAULT_MODEL=Qwen3.6-Plus

# ============================================================
# LLM 模型配置 (JSON 格式，唯一配置入口)
# 新增/修改模型只需编辑这里，无需改代码
# 格式: [{"name": "显示名", "model": "模型ID", "api_key": "密钥", "base_url": "API地址", "priority": 优先级}]
# ============================================================
LLM_CONFIGS=[{"name": "Qwen3.6-35B-A3B", "model": "Qwen3.6-35B-A3B-FP8", "api_key": "YOUR_API_KEY", "base_url": "https://your-private-api.com/chat/v1", "priority": 10}, {"name": "Qwen2.5-7B", "model": "Qwen/Qwen2.5-7B-Instruct", "api_key": "YOUR_API_KEY", "base_url": "https://api.siliconflow.cn/v1", "priority": 8}, {"name": "Qwen3-4B", "model": "qwen3-4b", "api_key": "YOUR_API_KEY", "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1", "priority": 6}, {"name": "Qwen3.6-Plus", "model": "qwen3.6-plus", "api_key": "YOUR_API_KEY", "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1", "priority": 9}, {"name": "DeepSeek-V3", "model": "deepseek-chat", "api_key": "YOUR_API_KEY", "base_url": "https://api.deepseek.com", "priority": 7}, {"name": "DeepSeek-R1", "model": "deepseek-reasoner", "api_key": "YOUR_API_KEY", "base_url": "https://api.deepseek.com", "priority": 8}, {"name": "GLM-4.7-Flash", "model": "glm-4.7-flash", "api_key": "YOUR_API_KEY", "base_url": "https://open.bigmodel.cn/api/paas/v4", "priority": 5}, {"name": "Nemotron-30B", "model": "nvidia/nemotron-3-nano-30b-a3b", "api_key": "YOUR_API_KEY", "base_url": "https://integrate.api.nvidia.com/v1", "priority": 4}, {"name": "Kimi-K2", "model": "moonshotai/kimi-k2-thinking", "api_key": "YOUR_API_KEY", "base_url": "https://integrate.api.nvidia.com/v1", "priority": 3}, {"name": "MiniMax-M2", "model": "minimaxai/minimax-m2", "api_key": "YOUR_API_KEY", "base_url": "https://integrate.api.nvidia.com/v1", "priority": 2}]

# ============================================================
# 文档解析
# ============================================================
MINERU_API_URL=https://mineru.net/api/v4
MINERU_API_KEY=YOUR_MINERU_API_KEY

# ============================================================
# 文档向量解析 - Embedding & Reranker
# ============================================================
# Provider: bge_m3 | dashscope | hash
DOCS_EMBEDDING_PROVIDER=bge_m3
DOCS_VECTORSTORE_PROVIDER=chroma
DOCS_EMBEDDING_DIMENSION=1024
DOCS_EMBEDDING_MODEL=bge-m3

# 在线 API（优先）
DOCS_EMBEDDING_API_KEY=YOUR_EMBEDDING_API_KEY
DOCS_EMBEDDING_API_URL=https://ai.bim-ace.com/bge/v1

# 本地部署（在线失败时自动降级）
DOCS_EMBEDDING_LOCAL_API_KEY=not-needed
DOCS_EMBEDDING_LOCAL_API_URL=http://localhost:7997/v1

# Reranker
DOCS_RERANKER_PROVIDER=cross_encoder
DOCS_RERANKER_MODEL=bge-reranker-v2-m3
DOCS_RERANKER_API_KEY=YOUR_RERANKER_API_KEY
DOCS_RERANKER_API_URL=https://ai.bim-ace.com/bge-reranker
DOCS_RERANKER_LOCAL_API_KEY=not-needed
DOCS_RERANKER_LOCAL_API_URL=http://localhost:7998

# --- 日志级别 ---
LOG_LEVEL=INFO
