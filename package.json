{
  "name": "angineer",
  "version": "0.1.04",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm run --parallel dev:*",
    "dev:frontend": "pnpm --filter @angineer/web-console dev",
    "dev:admin": "pnpm --filter @angineer/admin-console dev",
    "dev:backend": "python services/api-server/main.py",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter @angineer/web-console build",
    "build:admin": "pnpm --filter @angineer/admin-console build",
    "lint": "pnpm -r lint",
    "services:install": "pip install -e services/ai-inference -e services/angineer-core -e services/sop-core -e services/docs-core -e services/geo-core -e services/engtools -e services/evals-core",
    "dev:ai-inference": "pwsh -File services/ai-inference/start-ai-services.ps1",
    "stop:ai-inference": "pwsh -File services/ai-inference/start-ai-services.ps1 -Stop",
    "api:dev": "python services/api-server/main.py",
    "harness": "python -m unittest discover -s tests -p \"test_*.py\"",
    "harness:workflow": "python -m unittest tests.integration.test_05_Q1_with_reports",
    "harness:tooling": "python -m unittest tests.integration.test_01_tool_registration",
    "eval:list": "python -c \"from evals_core.storage.result_store import init_db, list_datasets; init_db(); import json; print(json.dumps(list_datasets(), ensure_ascii=False, indent=2))\"",
    "docs:sync": "python tools/sync_tech_docs.py",
    "docs:check": "python tools/check_docs_suite.py",
    "docs:arch-check": "python tools/check_architecture_docs.py"
  }
}
